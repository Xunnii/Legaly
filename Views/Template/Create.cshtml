@model Legaly.Web.Models.ViewModels.TemplateFormViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Tambah Template";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Tambah Template Baru</h4>
    <a href="/template" class="btn btn-secondary">Kembali</a>
</div>

<div class="card">
    <div class="card-body">
        <form method="post" action="/template/create">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Nama Template</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Content" class="form-label">Konten Template</label>
                <textarea asp-for="Content" class="form-control" rows="15"></textarea>
                <span asp-validation-for="Content" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Simpan</button>
                <a href="/template" class="btn btn-secondary">Batal</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
